# Copy to .env (Next.js also loads .env.local for local overrides)
# resilient-llm: https://www.npmjs.com/package/resilient-llm · https://github.com/gitcommitshow/resilient-llm

# --- Provider (biggest cost lever) ---
PREFERRED_AI_SERVICE=openai
PREFERRED_AI_MODEL=gpt-5.4-nano
OPENAI_API_KEY=sk-your-key-here

# Free alternative — https://openrouter.ai/keys (no credit card)
# PREFERRED_AI_SERVICE=openrouter
# PREFERRED_AI_MODEL=openrouter/free
# OPENROUTER_API_KEY=sk-or-your-key-here

# --- Generation (tutor behavior) ---
AI_TEMPERATURE=0.6
# AI_TOP_P=1
# AI_REASONING_EFFORT=low

# --- Cost caps (short 1–3 sentence JSON replies per turn) ---
MAX_COMPLETION_TOKENS=512
MAX_TOKENS=512
MAX_INPUT_TOKENS=12000

# --- Resilience (latency + retry spend) ---
LLM_TIMEOUT=20000
LLM_RETRIES=3
LLM_BACKOFF_FACTOR=2
RATE_LIMIT_RPM=30
RATE_LIMIT_TPM=60000
