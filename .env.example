# LingoQuest LLM configuration (OpenAI-compatible chat completions API).
# Copy this file to .env.local and fill in your values.
#
# Only OPENAI_API_KEY is required. OPENAI_BASE_URL and OPENAI_MODEL have
# sensible defaults and can be omitted.

# Your OpenAI API key (kept server-side only, never exposed to the browser).
OPENAI_API_KEY=sk-your-key-here

# Base URL for an OpenAI-compatible API. Default: https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model to use. Default: gpt-5.4-nano (latest low-cost GPT nano model).
# OPENAI_MODEL=gpt-5.4-nano
